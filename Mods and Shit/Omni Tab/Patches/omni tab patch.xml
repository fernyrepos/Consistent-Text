<?xml version="1.0" encoding="utf-8" ?>
<Patch>          


                <Operation Class="PatchOperationFindMod">
                    <mods>
                    <li>Discoveries</li>
                    </mods>
                    <match Class="PatchOperationSequence">
                    <operations>


                        <li Class="PatchOperationReplace">
                            <success>Always</success>
                            <xpath>Defs/MainButtonDef[defName="OmniTabButton"]/label</xpath>
                            <value>
                                <label>discoveries</label>
                            </value>
                        </li>

                        <li Class="PatchOperationReplace">
                            <success>Always</success>
                            <xpath>Defs/MainButtonDef[defName="OmniTabButton"]/description</xpath>
                            <value>
                                <description>See the elements of the world you have discovered, and examine or compare their attributes.</description>
                            </value>
                        </li>

                    </operations>
                    </match>
                </Operation>


</Patch>